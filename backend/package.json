{
  "name": "job-portal-backend",
  "version": "1.0.0",
  "description": "Production Ready Job Portal REST API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:migrate": "knex migrate:latest --knexfile knexfile.js",
    "db:rollback": "knex migrate:rollback --knexfile knexfile.js",
    "db:seed": "knex seed:run --knexfile knexfile.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.3.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.1",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.7.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "private": true
}
